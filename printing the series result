#include<stdio.h>
int factorial(int x)
{ int fact,i;
  for(i=1;i<=x;i++)
  fact=fact*i;
  return fact;
}
int main()
{ int n,j;
  float series=0;
  printf("enter the value of n");
  scanf("%d",&n);
  printf("the series is:\n");
  for(j=0;j<=n;j++)
  {series=series+(float)j/factorial(j);
  }
  printf("%f",series);
  return 0;
}
  
  
    
