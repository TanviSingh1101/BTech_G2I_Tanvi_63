#include<iostream>
using namespace std;
int main()
{
    int i,j,mat1[100][100],mat2[100][100],n,m,count=0;
    cout<<"Enter the dimension of matrix";
    cin>>n>>m;
    cout<<"Enter the elements of matrix";
    for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            cin>>mat1[i][j];
        }
    }
    for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            mat2[i][j]=mat1[j][i];
        }
    }
    for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            if (mat1[i][j]==mat2[i][j])
            {
                count++;
            }
        }
    }
    if(count==n*m)
    {
        cout<<"It is a symmetric matrix";
    }
    else
    cout<<"Its not a symmetric matrix";
    return 0;
}
