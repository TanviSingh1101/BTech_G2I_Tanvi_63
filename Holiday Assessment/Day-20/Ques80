#include<iostream>
using namespace std;
int main()
{
    int i,j,mat[100][100],sum=0,n,m;
    cout<<"Enter the dimension of the matrix";
    cin>>n>>m;
    cout<<"Enter the elements of the matrix";
    for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            cin>>mat[i][j];
        }
    }
    for(i=0;i<n;i++)
    {
        sum=0;
        for(j=0;j<m;j++)
        {
        sum=sum+mat[i][j];
        }
        cout<<"The row wise sum is "<<sum;
    }
    
    return 0;
}
