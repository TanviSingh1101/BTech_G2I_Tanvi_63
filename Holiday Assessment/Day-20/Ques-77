#include<iostream>
using namespace std;
int main()
{ int mat1[100][100],mat2[100][100],i,j,k,product[100][100],n1,m1,m,n;
cout<<"Enter the dimension of matrix 1";
cin>>n>>m;
cout<<"Enter the dimension of matrix 2";
cin>>n1>>m1;
if(m!=n1)
{ 
    cout<<"The product is not possible";
}
else
{
    cout<<"Enter the elements of matrix 1";
for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            cin>>mat1[i][j];
        }
    }
    cout<<"Enter the elements of matrix 2";
    for(i=0;i<n1;i++)
    {
        for(j=0;j<m1;j++)
        {
            cin>>mat2[i][j];
        }
    }
    for(i=0;i<n;i++)
    {
        for(j=0;j<m1;j++)
        {
        for(k=0;k<m;k++)
        {
            product[i][j]+=mat1[i][k]*mat2[k][j];
        }
        }
    }
for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            cout<<" "<<product[i][j];
        }
        cout<<endl;
    }}
    return 0;
}
