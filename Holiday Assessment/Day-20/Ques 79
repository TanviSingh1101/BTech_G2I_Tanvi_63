#include<iostream>
using namespace std;
int main ()
{
    int i,j,n,m,sum,mat[100][100];
    cout<<"Enter the dimension of the matrix";
    cin>>n>>m;
    cout<<"Enter the elements of the matrix";
    for(i=0;i<n;i++)
    {
        for(j=0;j<m;j++)
        {
            cin>>mat[i][j];
        }
    }
    cout<<"The column wide sum is";
    for(j=0;j<m;j++)
    {
        sum=0;
        for(i=0;i<n;i++)
        {
            sum=sum+mat[i][j];
        }
        cout<<sum<<"\n";
    }
    return 0;
}
