#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int i,n,vowel=0,consonant=0;
    char str[100];
    cout<<"Enter the string ";
    cin>>str;
    n=strlen(str);
    for(i=0;i<n;i++)
    {
      if(str[i]=='a'||str[i]=='A'||str[i]=='e'||str[i]=='E'||str[i]=='i'||str[i]=='I'||str[i]=='o'||str[i]=='O'||str[i]=='u'||str[i]=='U')
      vowel++;
      else
      consonant++;
    }
    cout<<"The vowel in string is "<<vowel<<" Consonant "<<consonant;
    return 0 ;
}
