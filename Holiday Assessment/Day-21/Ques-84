#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int i,n;
    char str[100];
    cout<<"Enter the string ";
    cin>>str;
    n=strlen(str);
    for(i=0;i<n;i++)
    {
     if(str[i]>='A'&&str[i]<='Z')
     str[i]=tolower(str[i]);
    else
    str[i]=toupper(str[i]);
    }
    cout<<"The new string is ";
    for(i=0;i<n;i++)
    cout<<str[i];
    return 0 ;
}
