#include<iostream>
#include<cstring>
#include<algorithm>
using namespace std;
int main()
{
   int n,i,j;
   char str[100],rst[100];
   cout<<"Enter the string ";
   cin.getline(str,100);
   n=strlen(str);
   j=0;
   for(i=0;i<n;i++)
   { 
       std::sort(str,str+n);
       if(str[i]!=str[i+1])
       {
       rst[j]=str[i];
       j++;
       }
   }
   cout<<"The new string is "<<rst;
   return 0 ;
}
