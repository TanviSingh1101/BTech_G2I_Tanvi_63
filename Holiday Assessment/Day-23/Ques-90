#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int n,i,find,count=0,j;
    char str[100];
    cout<<"Enter the string ";
    cin.getline(str,100);
    n=strlen(str);
    for(i=0;i<n-1;i++)
    {
       for(j=i+1;j<n;j++)
       {
           if (str[i]==str[j])
           count++;
       }
        if(count==1)
        {
        cout<<"The first repeating character is "<<str[i];
        return 0;
        }
        else
        count=0;
    }
    cout<<"There's no such element";
    return 0;
}
