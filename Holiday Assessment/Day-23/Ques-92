#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int n,i,j,count=1,max=0;
    char str[100],flag;
    cout<<"Enter the string ";
    cin.getline(str,100);
    n=strlen(str);
    for(i=0;i<n-1;i++)
    {
        for(j=i+1;j<n;j++)
        {
            if(str[i]==str[j])
            count++;
        }
        if(count>max)
        {
        max=count;
        flag=str[i];
        }
        else
        count=0;
    }
    cout<<"The maximum frequency is "<<max<<" of "<<flag;
    return 0;
}
