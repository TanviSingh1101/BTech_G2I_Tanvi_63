#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    int n,i,j;
    char str[100],rst[100];
    cout<<"Enter the string";
    cin>>str;
    n=strlen(str);
    j=0;
    for(i=n-1;i>=0;i--)
    {
        rst[j]=str[i];
        j++;
    }
    for(i=0;i<n;i++)
    {
        if(str[i]!=rst[i])
       { cout<<"Its not a pallindrome string";
        return 0;
       }
        
    }
    cout<<"Its a pallindrome string";
    return 0;
}
